local function dims()
    local ok, info = pcall(function() return gpu.getDisplayInfo(displayId) end)
    if not ok or type(info) ~= "table" then return 320, 240 end
    return (info.pixelWidth or 320), (info.pixelHeight or 240)
end

-- Bresenham line from small fillRects.  For thickness > 1 the dab is
-- biased along the minor axis so diagonals stay visually centred and
-- don't bloom into squares -- noticeably crisper at higher res.
local function gline(x0, y0, x1, y1, c, thick)
    thick = thick or 1
    x0 = math.floor(x0 + 0.5); y0 = math.floor(y0 + 0.5)
    x1 = math.floor(x1 + 0.5); y1 = math.floor(y1 + 0.5)
    local dx =  math.abs(x1 - x0)
    local dy = -math.abs(y1 - y0)
    local sx = (x0 < x1) and 1 or -1
    local sy = (y0 < y1) and 1 or -1
    local err = dx + dy
    -- Dab shape: if the line runs mostly horizontal, thicken vertically
    -- (a tall thin dab); if mostly vertical, thicken horizontally.
    local steep = (-dy) > dx
    local dw = steep and thick or 1
    local dh = steep and 1 or thick
    local ox = math.floor(dw / 2)
    local oy = math.floor(dh / 2)
    while true do
        gpu.fillRect(displayId, x0 - ox, y0 - oy, dw, dh, c[1], c[2], c[3])
        if x0 == x1 and y0 == y1 then break end
        local e2 = 2 * err
        if e2 >= dy then err = err + dy; x0 = x0 + sx end
        if e2 <= dx then err = err + dx; y0 = y0 + sy end
    end
end

local function grect(x, y, w, h, c)
    if w < 1 or h < 1 then return end
    gpu.fillRect(displayId, math.floor(x), math.floor(y),
                 math.floor(w), math.floor(h), c[1], c[2], c[3])
end

local function gtext(s, x, y, c, size, style)
    gpu.drawText(displayId, s, math.floor(x), math.floor(y),
                 c[1], c[2], c[3], "Arial", size or 10, style or "plain")
end

-- Sub-renderers (Graph:render, drawPFD, drawSidePanel) must NOT push
-- the display themselves -- doing so mid-frame shows a half-painted
-- screen (the bottom-panel flicker).  They call gflush() which is now
-- intentionally a no-op; the single real commit happens once per
-- frame in drawAll via gcommit().
local function gflush() end

local function gcommit()
    gpu.updateDisplay(displayId)
end


-- ================================================================
--  §5  SCROLLING GRAPH PRIMITIVE
--  ----------------------------------------------------------------
--  A reusable ring-buffer time-series plotter.  One Graph instance
--  per analysis panel; each holds N named series.  push() appends a
--  sample column; render() draws the framed, gridded, auto-windowed
--  chart with green/white/red traces.
-- ================================================================

local Graph = {}
Graph.__index = Graph

-- series = { {name=, color=}, ... }
function Graph.new(title, series, opts)
    opts = opts or {}
    return setmetatable({
        title   = title,
        series  = series,
        cap     = opts.cap or 80,    -- retained samples = on-screen
                                     -- history.  Small window: less
                                     -- clutter, each new sample is a
                                     -- bigger horizontal step, so the
                                     -- scroll reads as much faster.
                                     -- this is ~140 real ticks of history
        data    = {},                -- data[i] = { v1, v2, ... }
        head    = 0,                 -- ring write index
        count   = 0,
        fixed_hi = opts.fixed_hi,    -- nil => autoscale
        fixed_lo = opts.fixed_lo,
        unit    = opts.unit or "",
        danger  = opts.danger,       -- abs value beyond which a trace turns red
    }, Graph)
end

-- Interpolated sub-samples per real sample.  1 = raw (each control
-- tick advances exactly one column -- snappy, no smoothing ramp).
-- Higher values glide but soften transients and add on-screen
-- history; that fights the "less info, faster feel" goal, so this
-- is kept at 1.  Bump only if you want gliding back.
Graph.SUBSTEPS = 1

function Graph:push(values)
    local prev
    if self.count > 0 then
        prev = self.data[self.head]
    end
    local steps = Graph.SUBSTEPS
    if not prev then steps = 1 end
    for s = 1, steps do
        local col
        if steps == 1 then
            col = values
        else
            -- linear blend prev -> values
            local t = s / steps
            col = {}
            for k, v in pairs(values) do
                local pv = prev[k]
                if type(v) == "number" and type(pv) == "number" then
                    col[k] = pv + (v - pv) * t
                else
                    col[k] = v
                end
            end
        end
        self.head = (self.head % self.cap) + 1
        self.data[self.head] = col
        if self.count < self.cap then self.count = self.count + 1 end
    end
end

function Graph:clear()
    self.data = {}; self.head = 0; self.count = 0
end

-- chronological i-th sample (1 = oldest retained)
function Graph:_at(i)
    local start = (self.count < self.cap) and 1 or (self.head % self.cap) + 1
    local idx = ((start - 1 + (i - 1)) % self.cap) + 1
    return self.data[idx]
end

-- Compute the vertical window (cached so it can detect when an
-- autoscaling graph's range actually changes vs. stays put).
function Graph:_window()
    local hi, lo = self.fixed_hi, self.fixed_lo
    if not hi or not lo then
        hi, lo = -1e9, 1e9
        for i = 1, self.count do
            local col = self:_at(i)
            if col then
                for _, s in ipairs(self.series) do
                    local v = col[s.key or s.name]
                    if v then
                        if v > hi then hi = v end
                        if v < lo then lo = v end
                    end
                end
            end
        end
        if hi <= lo then hi = lo + 1 end
        local pad = (hi - lo) * 0.12
        hi = hi + pad; lo = lo - pad
        -- Quantise so tiny jitter doesn't force constant chrome
        -- repaints; only a meaningful range shift redraws the gutter.
        local span = hi - lo
        local q    = span / 20
        hi = math.ceil(hi / q) * q
        lo = math.floor(lo / q) * q
    end
    return hi, lo
end

-- Layout geometry shared by chrome + trace passes.
function Graph:_geom(px, py, pw, ph)
    local GUTTER = 34
    return {
        GUTTER = GUTTER,
        plotX  = px + GUTTER,
        plotY  = py + 22,
        plotW  = pw - GUTTER - 6,
        plotH  = ph - 28,
    }
end

-- STATIC chrome: card border, title, legend, gutter, gridlines and
-- axis numbers.  Drawn once on mode-entry and again only when an
-- autoscaling window shifts.  Never drawn on a routine tick, so a
-- dirty-region renderer leaves all these pixels untouched.
function Graph:renderChrome(px, py, pw, ph)
    grect(px, py, pw, ph, CK)
    grect(px, py, pw, 1, CW)                       -- top
    grect(px, py, 1, ph, CW)                       -- left
    grect(px, py + ph - 1, pw, 1, CGD)             -- bottom (dim)
    grect(px + pw - 1, py, 1, ph, CGD)             -- right  (dim)

    gtext(self.title, px + 8, py + 5, CW, 11, "bold")

    local lx = px + pw - 10
    for i = #self.series, 1, -1 do
        local s   = self.series[i]
        local txt = s.name
        lx = lx - (#txt * 6) - 16
        grect(lx, py + 6, 9, 9, s.color)
        grect(lx, py + 6, 9, 1, CW)
        gtext(txt, lx + 13, py + 5, CW, 9, "plain")
    end
    grect(px + 1, py + 18, pw - 2, 1, CGD)

    local g  = self:_geom(px, py, pw, ph)
    if g.plotW < 8 or g.plotH < 8 then return end
    local hi, lo = self:_window()
    self._chrome = { px=px, py=py, pw=pw, ph=ph, hi=hi, lo=lo }

    grect(px + 1, g.plotY, g.GUTTER - 1, g.plotH, CK)
    grect(g.plotX - 1, g.plotY, 1, g.plotH, CGD)

    for gi = 0, 4 do
        local frac = gi / 4
        local val  = hi - (hi - lo) * frac
        local gy   = g.plotY + frac * (g.plotH - 1)
        gy = math.max(g.plotY, math.min(g.plotY + g.plotH - 1, gy))
        grect(g.plotX, gy, g.plotW, 1, CGD)
        grect(g.plotX - 4, gy, 4, 1, CGY)
        local lbl = string.format("%.1f", val)
        gtext(lbl, g.plotX - 7 - (#lbl * 5), gy - 4, CGY, 8, "plain")
    end
end

-- DYNAMIC trace: clears ONLY the plot interior and repaints the
-- scrolling traces, zero line, leading dot and value flags.  This is
-- the only thing that runs every tick.  If the autoscaling window
-- has drifted past the cached one, it requests a chrome repaint via
-- the return value so the caller can re-issue renderChrome.
-- Returns true if chrome is still valid, false if it needs redrawing.
function Graph:renderTrace(px, py, pw, ph, scrollFrac)
    scrollFrac = scrollFrac or 0
    local g = self:_geom(px, py, pw, ph)
    if g.plotW < 8 or g.plotH < 8 then return true end

    local hi, lo = self:_window()
    local ch = self._chrome
    if not ch or ch.hi ~= hi or ch.lo ~= lo
       or ch.px ~= px or ch.py ~= py or ch.pw ~= pw or ch.ph ~= ph then
        -- Window/geometry moved: caller must repaint chrome first.
        return false
    end

    -- Clear only the interior (leaves gutter numbers + border intact).
    grect(g.plotX, g.plotY, g.plotW, g.plotH, CK)

    -- Faint gridlines inside the interior (chrome's were cleared away)
    for gi = 0, 4 do
        local frac = gi / 4
        local gy   = g.plotY + frac * (g.plotH - 1)
        gy = math.max(g.plotY, math.min(g.plotY + g.plotH - 1, gy))
        grect(g.plotX, gy, g.plotW, 1, CGD)
    end

    local function yOf(v)
        local f = (hi - v) / (hi - lo)
        if f < 0 then f = 0 elseif f > 1 then f = 1 end
        return g.plotY + f * (g.plotH - 1)
    end

    if lo < 0 and hi > 0 then
        local zy = yOf(0)
        for xx = g.plotX, g.plotX + g.plotW - 1, 7 do
            grect(xx, zy, 4, 1, CW)
        end
    end

    if self.count >= 2 then
        local n = self.count
        -- One sample's pixel width.  The whole trace is shifted left
        -- by scrollFrac of this, so between data arrivals the line
        -- glides continuously instead of stepping once per tick.
        local colW = (g.plotW - 1) / (n - 1)
        local xL   = g.plotX
        local xR   = g.plotX + g.plotW - 1
        local flags = {}   -- collected, de-conflicted, then drawn
        for _, s in ipairs(self.series) do
            local key = s.key or s.name
            local prevX, prevY, prevClipped
            local lastX, lastY, lastV
            for i = 1, n do
                local col = self:_at(i)
                local v   = col and col[key]
                if v ~= nil then
                    local xx = g.plotX + (i - 1) * colW - scrollFrac * colW
                    local yy = yOf(v)
                    local c  = s.color
                    if self.danger and math.abs(v) > self.danger then
                        c = CR
                    end
                    -- Only draw the segment if at least partly inside
                    -- the plot interior (prevents gutter bleed as the
                    -- oldest point slides off the left).
                    if prevX and not (xx < xL and prevX < xL)
                              and not (xx > xR and prevX > xR) then
                        local ax, ay, bx, by = prevX, prevY, xx, yy
                        if ax < xL then ax = xL end
                        if bx < xL then bx = xL end
                        if ax > xR then ax = xR end
                        if bx > xR then bx = xR end
                        gline(ax, ay, bx, by, c, 2)
                    end
                    prevX, prevY = xx, yy
                    if xx <= xR + 0.5 then
                        lastX, lastY, lastV = math.min(xx, xR), yy, v
                    end
                end
            end
            if lastX then
                local c = s.color
                if self.danger and lastV and math.abs(lastV) > self.danger then
                    c = CR
                end
                -- Leading-edge marker drawn now (its position is exact);
                -- the value flag is deferred for overlap resolution.
                grect(lastX - 2, lastY - 2, 5, 5, c)
                grect(lastX - 1, lastY - 1, 3, 3, CW)
                local txt  = string.format("%.1f", lastV or 0)
                flags[#flags + 1] = {
                    yIdeal = lastY,        -- where it WANTS to sit
                    color  = c,
                    text   = txt,
                    w      = #txt * 6 + 8,
                    dotY   = lastY,        -- the trace point it labels
                }
            end
        end

        -- ---- Flag de-confliction ----
        -- Each flag is FH px tall.  Sort by desired Y, then sweep
        -- downward pushing any flag that would overlap the previous
        -- one; finally clamp the whole stack inside the plot and, if
        -- it still overflows, sweep back upward.  Result: no two flag
        -- boxes ever intersect, each kept as near its trace as the
        -- geometry allows.
        local FH   = 11
        local GAP  = 1
        local top  = g.plotY
        local bot  = g.plotY + g.plotH - FH
        table.sort(flags, function(a, b) return a.yIdeal < b.yIdeal end)
        local nF = #flags
        for i = 1, nF do
            local f = flags[i]
            f.y = math.max(top, math.min(bot, f.yIdeal - 5))
            if i > 1 then
                local prev = flags[i - 1]
                if f.y < prev.y + FH + GAP then
                    f.y = prev.y + FH + GAP
                end
            end
        end
        -- If the bottom-most got pushed past the plot, walk back up.
        if nF > 0 and flags[nF].y > bot then
            flags[nF].y = bot
            for i = nF - 1, 1, -1 do
                local below = flags[i + 1]
                if flags[i].y + FH + GAP > below.y then
                    flags[i].y = below.y - FH - GAP
                end
                if flags[i].y < top then flags[i].y = top end
            end
        end

        -- Draw the resolved flags, with a thin leader line back to the
        -- exact trace point when the flag had to be nudged away.
        for _, f in ipairs(flags) do
            local fw = f.w
            local fx = g.plotX + g.plotW - fw - 1
            local fy = f.y
            local cy = fy + 5      -- flag vertical centre
            -- leader: from the trace dot to the flag's left edge
            if math.abs(cy - f.dotY) > 2 then
                gline(fx, cy, fx - 6, f.dotY, f.color, 1)
            end
            grect(fx, fy, fw, FH, CK)
            grect(fx, fy, fw, 1, f.color)
            grect(fx, fy + FH - 1, fw, 1, f.color)
            grect(fx, fy, 1, FH, f.color)
            gtext(f.text, fx + 4, fy + 1, f.color, 8, "plain")
        end
    end
    return true
end

-- Convenience: full paint (chrome + trace).  Used on mode-entry and
-- whenever renderTrace reports the chrome is stale.
function Graph:render(px, py, pw, ph)
    self:renderChrome(px, py, pw, ph)
    self:renderTrace(px, py, pw, ph)
end


-- ================================================================
--  §6  PRIMARY FLIGHT DISPLAY  (glass cockpit)
--  ----------------------------------------------------------------
--  Layout (full DirectGPU surface):
--
--    +--------------------------------------------------+
--    | bank arc + roll pointer                          |
--    |        . . . pitch ladder . . .        | ALT TAPE|
--    |  ~~~~~~~~~~~ horizon ~~~~~~~~~~~~~~~~~  |  + VSI  |
--    |        (sky green-tint / ground dark)   |         |
--    |  fixed aircraft reference (white)       |         |
--    | numeric readouts band (bottom)                   |
--    +--------------------------------------------------+
--
--  Sky is rendered near-black with a faint green tint; ground is
--  pure black.  Horizon line, ladder, reference and tape framing
--  are white.  Green marks "good"/on-target; red appears only when
--  a limit is exceeded.
-- ================================================================

local LADDER     = { -30, -20, -10, 10, 20, 30 }
local BANK_MAJOR = { -60, -30, 0, 30, 60 }
local BANK_MINOR = { -50, -40, -20, -10, 10, 20, 40, 50 }
local TAPE_SCALE = 2.0     -- blocks per ... (tape is pixel-scaled below)

local C_SKY = { 14, 26, 20 }   -- near-black, faint green tint
local C_GND = { 6,  8,  7  }   -- near-black ground

local function drawPFD(d)
    local PW, PH = dims()

    -- Right-edge altitude tape reserves a vertical strip.
    local tapeW = math.max(54, math.floor(PW * 0.16))
    local tapeX = PW - tapeW
    local hzW   = tapeX                 -- horizon region width
    local hzH   = PH - 26               -- leave a readout band at the bottom
    local cx    = hzW * 0.5
    local cy    = hzH * 0.5

    local ppd   = hzH / 60.0            -- pixels per degree of pitch
    local pitchPx = d.pitch * ppd
    local tanR  = math.tan(math.rad(d.roll))

    -- ---- Sky / ground split (scanline fill) ----
    -- For speed it fills in horizontal bands of a few px; the horizon
    -- is a slanted line y = cy - pitchPx + (x-cx)*tanR.
    local BAND = 2
    for y = 0, hzH - 1, BAND do
        -- Decide, per band, the crossover x where horizon meets this y.
        -- Rather than per-pixel it draws two rects split at the midline
        -- crossing; with small BAND this is visually clean.
        local yMid = y + BAND * 0.5
        -- x where horizon is at yMid:  yMid = cy - pitchPx + (x-cx)tanR
        local segs = {}
        if math.abs(tanR) < 1e-4 then
            local horizY = cy - pitchPx
            local isSky  = yMid < horizY
            grect(0, y, hzW, BAND, isSky and C_SKY or C_GND)
        else
            local xCross = cx + (yMid - cy + pitchPx) / tanR
            xCross = math.max(0, math.min(hzW, xCross))
            -- Left part and right part are sky/ground depending on slope.
            local leftIsSky
            do
                local hy0 = cy - pitchPx + (0 - cx) * tanR
                leftIsSky = yMid < hy0
            end
            grect(0, y, xCross, BAND, leftIsSky and C_SKY or C_GND)
            grect(xCross, y, hzW - xCross, BAND,
                  leftIsSky and C_GND or C_SKY)
        end
    end

    -- ---- Horizon line (white, thick) ----
    do
        local x0, x1 = 0, hzW
        local y0 = cy - pitchPx + (x0 - cx) * tanR
        local y1 = cy - pitchPx + (x1 - cx) * tanR
        gline(x0, y0, x1, y1, CW, 3)
    end

    -- ---- Pitch ladder ----
    for _, deg in ipairs(LADDER) do
        local markCY = cy - (deg - d.pitch) * ppd
        if markCY >= 4 and markCY <= hzH - 4 then
            local half = 34
            -- rotate the rung endpoints about (cx, markCY) by roll
            local function rot(dx)
                local rx = cx + dx
                local ry = markCY + dx * tanR
                return rx, ry
            end
            local lx, ly = rot(-half)
            local rx, ry = rot( half)
            gline(lx, ly, rx, ry, CW, 1)
            local lbl = tostring(math.abs(deg))
            gtext(lbl, rx + 4, ry - 5, CW, 9, "plain")
            gtext(lbl, lx - 18, ly - 5, CW, 9, "plain")
        end
    end

    -- ---- Bank arc + roll pointer (top) ----
    local arcH   = 16
    local scaleB = hzW / 200.0
    grect(0, 0, hzW, arcH, CK)
    for _, deg in ipairs(BANK_MINOR) do
        local x = cx + deg * scaleB
        if x >= 1 and x <= hzW then grect(x, arcH - 5, 1, 5, CGY) end
    end
    for _, deg in ipairs(BANK_MAJOR) do
        local x = cx + deg * scaleB
        if x >= 1 and x <= hzW then
            grect(x, arcH - 8, 1, 8, CW)
            local lbl = (deg == 0) and "0" or tostring(math.abs(deg))
            gtext(lbl, x - (#lbl * 3), 1, CW, 8, "plain")
        end
    end
    -- roll pointer: triangle at the craft's current roll
    do
        local rollLim = math.abs(d.roll) > 30
        local pc = rollLim and CR or CG
        local x  = math.max(2, math.min(hzW - 2, cx + d.roll * scaleB))
        gline(x, arcH + 2, x - 5, arcH + 10, pc, 1)
        gline(x, arcH + 2, x + 5, arcH + 10, pc, 1)
        gline(x - 5, arcH + 10, x + 5, arcH + 10, pc, 1)
        -- fixed centre index
        grect(cx, arcH + 2, 1, 6, CW)
    end

    -- ---- Fixed aircraft reference (white wing bars + dot) ----
    do
        local rcx, rcy = math.floor(cx), math.floor(cy)
        grect(rcx - 30, rcy, 18, 2, CW)
        grect(rcx + 12, rcy, 18, 2, CW)
        grect(rcx - 2, rcy - 2, 4, 4, CW)
        grect(rcx - 1, rcy - 10, 2, 6, CW)   -- tail fin up-tick
    end

    -- ---- Altitude tape (right edge) ----
    do
        local tx, tH = tapeX, hzH
        grect(tx, 0, tapeW, PH, CK)
        grect(tx, 0, 1, PH, CW)               -- tape left border

        local tcx     = tx + tapeW * 0.5
        local centreY = tH * 0.5
        local pxPerM  = tH / 60.0             -- ~60m visible span
        local function altToY(a)
            return centreY - (a - d.alt) * pxPerM
        end

        -- tick + number ladder every 5 m, majors every 10 m
        local span    = 34
        local startA  = math.floor((d.alt - span) / 5) * 5
        local endA    = math.floor((d.alt + span) / 5) * 5
        for a = startA, endA, 5 do
            local yy = altToY(a)
            if yy >= 2 and yy <= tH - 2 then
                if a % 10 == 0 then
                    grect(tx + 2, yy, 8, 1, CW)
                    gtext(tostring(a), tx + 12, yy - 4, CGY, 8, "plain")
                else
                    grect(tx + 2, yy, 5, 1, CGY)
                end
            end
        end

        -- target bug (green, or red if far off)
        local err   = d.targetAlt - d.alt
        local farOff = math.abs(err) > 8
        local tgtY  = altToY(d.targetAlt)
        if tgtY >= 1 and tgtY <= tH then
            local bc = farOff and CR or CG
            gline(tx + 2, tgtY, tx + 10, tgtY - 5, bc, 1)
            gline(tx + 2, tgtY, tx + 10, tgtY + 5, bc, 1)
            gline(tx + 10, tgtY - 5, tx + 10, tgtY + 5, bc, 1)
            gtext("T" .. tostring(math.floor(d.targetAlt)),
                  tx + 13, tgtY - 4, bc, 8, "plain")
        end

        -- current-altitude readout box at centre (white frame, green text)
        local boxH = 16
        grect(tx + 1, centreY - boxH/2, tapeW - 2, boxH, CK)
        grect(tx + 1, centreY - boxH/2, tapeW - 2, 1, CW)
        grect(tx + 1, centreY + boxH/2, tapeW - 2, 1, CW)
        local onTgt = math.abs(err) < 1.5
        gtext(string.format("%.1f", d.alt),
              tx + 8, centreY - 5, onTgt and CG or CW, 11, "bold")

        -- VSI: thin column just inside the tape left border
        local vsiMax  = 10.0
        local vc      = math.max(-vsiMax, math.min(vsiMax, d.velY))
        local vRows   = math.abs(vc) / vsiMax * (tH * 0.40)
        local vcolor  = (vc >= 0) and CG or CGY
        if vc >= 0 then
            grect(tx + 3, centreY - vRows, 3, vRows, vcolor)
        else
            grect(tx + 3, centreY, 3, vRows, vcolor)
        end
        grect(tx + 2, centreY, 5, 1, CW)
    end

    -- ---- Bottom numeric readout band ----
    do
        local by = PH - 24
        grect(0, by, hzW, 24, CK)
        grect(0, by, hzW, 1, CW)

        local pLvl = math.abs(d.pitch) < 1.0
        local rLvl = math.abs(d.roll)  < 1.0

        gtext(string.format("PITCH %+5.1f", d.pitch),
              8, by + 4, pLvl and CG or CW, 10, "bold")
        gtext(string.format("ROLL %+5.1f", d.roll),
              8, by + 13, rLvl and CG or CW, 10, "bold")

        gtext(string.format("ALT %.1f", d.alt),
              math.floor(hzW * 0.34), by + 4, CW, 10, "bold")
        gtext(string.format("TGT %d", math.floor(d.targetAlt)),
              math.floor(hzW * 0.34), by + 13, CG, 10, "plain")

        gtext(string.format("VS %+.2f", d.velY),
              math.floor(hzW * 0.55), by + 4, CW, 10, "plain")
        gtext(string.format("RPM %.0f", d.rpm),
              math.floor(hzW * 0.55), by + 13, CG, 10, "bold")

        -- status word
        local status, sc
        if pLvl and rLvl and math.abs(d.targetAlt - d.alt) < 1.5
           and math.abs(d.velY) < 0.3 then
            status, sc = "STABLE", CG
        elseif math.abs(d.pitch) > 25 or math.abs(d.roll) > 25 then
            status, sc = "ATT LIMIT", CR
        else
            status, sc = "CORRECTING", CW
        end
        gtext(status, math.floor(hzW * 0.78), by + 8, sc, 11, "bold")
    end

    gflush()
end


