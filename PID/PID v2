-- Stab uses two stacked panels; alt uses two stacked panels;
-- ----------------------------------------------------------------
--  Side data panel.  Faithfully reproduces BOTH original text
--  panels (6flatgraph FLATSTAB + 5altgraph ALTSTAB) fused into one
--  vertical strip on the right of every graph mode.  Lime section
--  dividers, the same readouts, the same conditional colouring:
--    * pitch/roll/alt/err/vel go green when within tolerance
--    * gains go kP=lime kI=red kD=blue WHEN a *gains* mode is active
--      (matching the originals exactly); plain white otherwise
--    * motor flux bars are per-motor coloured in graph modes
--    * K / mass / pressure in grey
--  Returns the x where the graph area must stop (panel left edge).
-- ----------------------------------------------------------------
local SIDE_W_FRAC = 0.26
local function drawSidePanel(d, gainsKind)
    local PW, PH = dims()
    local pw = math.max(150, math.floor(PW * SIDE_W_FRAC))
    local x0 = PW - pw
    -- vertical separator
    grect(x0 - 1, 0, 1, PH, CW)
    grect(x0, 0, pw, PH, CK)

    local fs   = 11          -- panel font px
    local lh   = math.max(13, math.floor(fs * 1.25))
    local row  = 0
    local pad  = 6
    local function ln(t, c)
        local y = pad + row * lh
        row = row + 1
        if y > PH - lh then return end
        gtext(t, x0 + 6, y, c or CW, fs, "plain")
    end
    local function div()
        local y = pad + row * lh + math.floor(lh/2) - 1
        row = row + 1
        if y > PH - 2 then return end
        grect(x0 + 4, y, pw - 8, 1, CG)
    end
    local barW = pw - 56
    local function bar(lbl, rpm, col, lo, hi)
        local y = pad + row * lh
        row = row + 1
        if y > PH - lh then return end
        lo = lo or MOTOR_MIN; hi = hi or MOTOR_MAX
        local pct  = (rpm - lo) / (hi - lo)
        if pct < 0 then pct = 0 elseif pct > 1 then pct = 1 end
        local bars = math.floor(pct * barW + 0.5)
        gtext(lbl, x0 + 6, y, CW, fs, "plain")
        grect(x0 + 34, y + 2, bars, fs - 3, col)
        grect(x0 + 34 + bars, y + 2, barW - bars, fs - 3, CGD)
    end

    -- ---- STABILISER block ----
    local function blockStab()
        ln(" ATTITUDE", CG)
        div()
        local pLvl = math.abs(d.pitch) < 1.0
        local rLvl = math.abs(d.roll)  < 1.0
        ln(string.format(" P %+6.1f deg", d.pitch), pLvl and CG or CW)
        ln(string.format(" R %+6.1f deg", d.roll),  rLvl and CG or CW)
        div()
        ln(string.format(" wP %+5.3f r/s", d.angX))
        ln(string.format(" wR %+5.3f r/s", d.angZ))
        div()
        if gainsKind == "stab" then
            ln(string.format(" kP  %6.3f", S_KP), CG)
            ln(string.format(" kI  %6.3f", S_KI), CR)
            ln(string.format(" kD  %6.3f", S_KD), CB)
        else
            ln(string.format(" kP  %6.3f", S_KP))
            ln(string.format(" kI  %6.3f", S_KI))
            ln(string.format(" kD  %6.3f", S_KD))
        end
        ln(string.format(" BASE %5d", ATT_BASE))
        div()
        local function motorBar(lbl, rpm, col)
            local useCol = (UI_MODE == "stab_graph") and col or CW
            bar(lbl, rpm, useCol)
        end
        motorBar("FL", d.fl, { 90,220,130 })
        motorBar("FR", d.fr, { 235,220,90 })
        motorBar("BL", d.bl, { 90,200,235 })
        motorBar("BR", d.br, { 240,160,70 })
        div()
        ln(string.format(" iP %+5.2f", d.iP))
        ln(string.format(" iR %+5.2f", d.iR))
        div()
    end

    -- ---- ALTITUDE block ----
    local function blockAlt()
        ln(" ALTITUDE", CG)
        div()
        local err   = d.targetAlt - d.alt
        local onTgt = math.abs(err) < 1.5
        ln(string.format(" TGT %6.1f m",  d.targetAlt), CG)
        ln(string.format(" ALT %6.1f m",  d.alt),  onTgt and CG or CW)
        ln(string.format(" ERR %+6.1f m", err),
           math.abs(err) < 0.5 and CG or CW)
        div()
        ln(string.format(" VEL %+6.2f/s", d.velY),
           math.abs(d.velY) < 0.5 and CG or CW)
        div()
        -- Gains block (moved above the FF/PID/VD/RPM/GLM block).
        if gainsKind == "alt" then
            ln(string.format(" kP  %6.3f", A_KP),     CG)
            ln(string.format(" kI  %6.3f", A_KI),     CR)
            ln(string.format(" kD  %6.3f", A_KD_VEL), CB)
        else
            ln(string.format(" kP  %6.3f", A_KP))
            ln(string.format(" kI  %6.3f", A_KI))
            ln(string.format(" kD  %6.3f", A_KD_VEL))
        end
        ln(string.format(" ff  %6.2f", A_FALLBACK))
        div()
        -- Control-effort block (moved below the gains block).
        ln(string.format(" FF  %+6.1f",  d.ff))
        ln(string.format(" PID %+6.1f",  d.pidCorr))
        ln(string.format(" VD  %+6.1f",  -d.velDamp))
        ln(string.format(" RPM %6.0f",   d.rpm), CG)
        -- GLM power bar: the lift motor's commanded RPM as a fraction
        -- of full authority.  Green normally, red if it pins to the
        -- ceiling (saturated -> losing altitude authority).
        local glmRpm = d.glm or d.rpm or 0
        local glmCol = (glmRpm >= MOTOR_MAX - 1) and CR or CG
        bar("GLM", glmRpm, glmCol)
        div()
        if d.k then ln(string.format(" K  %.5f", d.k), CGY)
        else        ln(" K  warmup...",            CGY) end
        ln(string.format(" M  %.1f kg", d.mass),     CGY)
        ln(string.format(" Pa %.4f",    d.pressure), CGY)
        div()
        ln(string.format(" altI %+5.2f", d.altI))
    end

    -- Order so the ACTIVE mode's block is drawn first and therefore
    -- never clipped by running out of vertical space.  In alt modes
    -- the altitude block (incl. its kP/kI/kD) leads; in stab/pfd the
    -- stabiliser block leads.
    local altActive = (UI_MODE == "alt_graph" or UI_MODE == "alt_gains")
    if altActive then
        blockAlt(); blockStab()
    else
        blockStab(); blockAlt()
    end

    return x0 - 1   -- graph area must end here
end

-- Stacked panels get an outer pad and a gap between them so they read
-- as two distinct cards rather than one divided block.
local PANEL_PAD = 6     -- outer margin around the stack
local PANEL_GAP = 10    -- vertical gap between the two cards

-- Helper: paint one graph efficiently.  On a "full" pass it clears
-- its rect and draws chrome+trace; otherwise it draws trace only, and
-- if the graph reports its chrome went stale (autoscale window moved)
-- it transparently repaints chrome for just that graph.
local function paintGraph(G, x, y, w, h, full, scrollFrac)
    if full then
        G:renderChrome(x, y, w, h)
        G:renderTrace(x, y, w, h, scrollFrac)
    else
        local okChrome = G:renderTrace(x, y, w, h, scrollFrac)
        if not okChrome then
            G:renderChrome(x, y, w, h)
            G:renderTrace(x, y, w, h, scrollFrac)
        end
    end
end

local function stackGeom()
    local PW, PH = dims()
    local areaH  = PH - PANEL_PAD * 2
    local half   = math.floor((areaH - PANEL_GAP) / 2)
    return PW, PH, areaH, half
end

local function drawStabGraph(d, full, sf)
    local PW, PH, areaH, half = stackGeom()
    local gx = drawSidePanel(d, nil)         -- side panel: cheap, every tick
    local areaX, areaW, areaY = PANEL_PAD, gx - PANEL_PAD * 2, PANEL_PAD
    paintGraph(G_stab_flux, areaX, areaY, areaW, half, full, sf)
    paintGraph(G_stab_err,  areaX, areaY + half + PANEL_GAP,
               areaW, areaH - half - PANEL_GAP, full, sf)
end

local function drawStabGains(d, full, sf)
    local PW, PH = dims()
    G_stab_gain.fixed_hi =  GAINS_RANGE
    G_stab_gain.fixed_lo = -GAINS_RANGE
    local gx = drawSidePanel(d, "stab")
    paintGraph(G_stab_gain, PANEL_PAD, PANEL_PAD,
               gx - PANEL_PAD * 2, PH - PANEL_PAD * 2, full, sf)
end

local function drawAltGraph(d, full, sf)
    local PW, PH, areaH, half = stackGeom()
    local gx = drawSidePanel(d, nil)
    local areaX, areaW, areaY = PANEL_PAD, gx - PANEL_PAD * 2, PANEL_PAD
    paintGraph(G_alt_flux, areaX, areaY, areaW, half, full, sf)
    paintGraph(G_alt_trk,  areaX, areaY + half + PANEL_GAP,
               areaW, areaH - half - PANEL_GAP, full, sf)
end

local function drawAltGains(d, full, sf)
    local PW, PH = dims()
    G_alt_gain.fixed_hi =  GAINS_RANGE
    G_alt_gain.fixed_lo = -GAINS_RANGE
    local gx = drawSidePanel(d, "alt")
    paintGraph(G_alt_gain, PANEL_PAD, PANEL_PAD,
               gx - PANEL_PAD * 2, PH - PANEL_PAD * 2, full, sf)
end


-- ================================================================
--  §8  MASTER DRAW DISPATCH
-- ================================================================

-- Ingest one new telemetry sample into the ring buffers.  Called
-- EXACTLY ONCE per control tick (when FRAME.seq advances), regardless
-- of how many times the screen is repainted -- otherwise a 60 Hz
-- render loop would consume the buffer 3x too fast.
local function ingestFrame(d)
    G_stab_flux:push({ FL=d.fl, FR=d.fr, BL=d.bl, BR=d.br })
    G_stab_err:push({ pitch=d.pitch, roll=d.roll })
    G_stab_gain:push({
        kP = S_KP * (-d.pitch),
        kI = S_KI * d.iP,
        kD = -(S_KD * d.angX),
    })
    G_alt_flux:push({ rpm = d.rpm })
    G_alt_trk:push({ alt = d.alt, target = d.targetAlt })
    G_alt_gain:push({
        kP = A_KP * (d.targetAlt - d.alt),
        kI = A_KI * d.altI,
        kD = -d.velDamp,
    })
end

-- Render the current screen.  Called every render-loop iteration.
-- sf (scrollFrac, 0..1) slides graph traces a sub-column left so the
-- line glides smoothly between control-tick data arrivals.
local function renderFrame(d, sf)
    if not gpu then return end
    if not displayId then
        if not gpuEnsure() then return end
    end
    if not d then return end

    local full = UI_DIRTY

    if UI_MODE == "pfd" then
        drawPFD(d)
    elseif UI_MODE == "stab_graph" then
        if full then local PW,PH=dims(); grect(0,0,PW,PH,CK) end
        drawStabGraph(d, full, sf)
    elseif UI_MODE == "stab_gains" then
        if full then local PW,PH=dims(); grect(0,0,PW,PH,CK) end
        drawStabGains(d, full, sf)
    elseif UI_MODE == "alt_graph" then
        if full then local PW,PH=dims(); grect(0,0,PW,PH,CK) end
        drawAltGraph(d, full, sf)
    elseif UI_MODE == "alt_gains" then
        if full then local PW,PH=dims(); grect(0,0,PW,PH,CK) end
        drawAltGains(d, full, sf)
    end

    UI_DIRTY = false
    gcommit()
end


-- ================================================================
--  §9  QUATERNION / PHYSICS HELPERS
-- ================================================================

local function getPitchRoll(q)
    local pitchRad, _, rollRad = q:toEuler()
    return math.deg(pitchRad), math.deg(rollRad)
end

local k_est = nil   -- online lift coefficient

local function getFeedforward(pressure, mass, gravity)
    if not pressure or pressure == 0 then return 0 end
    if k_est then return (mass * gravity) / (k_est * pressure)
    else          return A_FALLBACK / pressure
    end
end

local function updateK(mass, gravity, vertAccel, avgRPM, pressure)
    if avgRPM < K_MIN_RPM            then return end
    if not pressure or pressure == 0 then return end
    local lift = mass * (gravity + vertAccel)
    if lift <= 0                     then return end
    local kNew = lift / (avgRPM * pressure)
    k_est = k_est and (k_est * (1 - K_ALPHA) + kNew * K_ALPHA) or kNew
end

local function clamp(v, lo, hi) return math.max(lo, math.min(hi, v)) end


-- ================================================================
--  §10  MOTORS
-- ================================================================

local M = {}

local function wrapMotors(cfg)
    local function w(name, lbl)
        local p = peripheral.wrap(name)
        if not p then error(lbl .. " not found: " .. name) end
        return p
    end
    M.GLM = w(cfg.GLM, "GLM")
    M.FL  = w(cfg.FL, "FL"); M.FR = w(cfg.FR, "FR")
    M.BL  = w(cfg.BL, "BL"); M.BR = w(cfg.BR, "BR")
end

-- Split-channel mixer for the real airframe:
--   * GLM lift motor  <- altitude collective (full lift authority)
--   * 4 corner rotors <- ATT_BASE +/- attitude trim ONLY (no lift)
--
-- The corner rotors idle at ATT_BASE so the stabiliser can push a
-- corner both UP (+trim) and DOWN (-trim).  They contribute no net
-- lift in the balanced case (the +/- pairs cancel); all sustained
-- lift comes from the GLM.  Returns glm + the four corner speeds.
local function setMotors(coll, pitchOut, rollOut)
    local glm = clamp(coll, MOTOR_MIN, MOTOR_MAX)
    local fl  = clamp(ATT_BASE + pitchOut + rollOut, MOTOR_MIN, MOTOR_MAX)
    local fr  = clamp(ATT_BASE + pitchOut - rollOut, MOTOR_MIN, MOTOR_MAX)
    local bl  = clamp(ATT_BASE - pitchOut + rollOut, MOTOR_MIN, MOTOR_MAX)
    local br  = clamp(ATT_BASE - pitchOut - rollOut, MOTOR_MIN, MOTOR_MAX)
    M.GLM.setTargetSpeed(glm)
    M.FL.setTargetSpeed(fl); M.FR.setTargetSpeed(fr)
    M.BL.setTargetSpeed(bl); M.BR.setTargetSpeed(br)
    return glm, fl, fr, bl, br
end

local function stopMotors()
    for _, m in pairs(M) do pcall(function() m.setTargetSpeed(0) end) end
end


-- ================================================================
--  §11  CONTROL LOOP  (both laws every tick, superposed)
-- ================================================================

local pitchPID, rollPID, altPID

local function makeControlStep()
    local lastTime = os.clock()
    local prevVelY = 0
    local lastColl = 0

    return function()
        local now = os.clock()
        local dt  = math.max(now - lastTime, 0.001)
        lastTime  = now

        -- ---- Sense ----
        local pose    = sublevel.getLogicalPose()
        local pos     = pose.position
        local angVel  = sublevel.getAngularVelocity()
        local linVel  = sublevel.getLinearVelocity()
        local mass    = sublevel.getMass()
        local pitch, roll = getPitchRoll(pose.orientation)

        local pressure = aero.getAirPressure(pos)
        local gravVec  = aero.getGravity()
        local gravity  = math.abs(gravVec.y)

        local velY      = linVel.y
        local vertAccel = (velY - prevVelY) / dt
        prevVelY        = velY

        -- ---- Altitude law (collective) ----
        updateK(mass, gravity, vertAccel, lastColl, pressure)
        local ff      = getFeedforward(pressure, mass, gravity)
        local pidCorr = altPID:step(pos.y, dt)
        local velDamp = A_KD_VEL * velY
        local coll    = clamp(ff + pidCorr - velDamp, MOTOR_MIN, MOTOR_MAX)
        lastColl      = coll

        -- ---- Attitude law (differential trim) ----
        if math.abs(roll)  > DISTURBANCE_DEG then
            rollPID.integral  = rollPID.integral  * INTEGRAL_BLEED
        end
        if math.abs(pitch) > DISTURBANCE_DEG then
            pitchPID.integral = pitchPID.integral * INTEGRAL_BLEED
        end
        local pitchOut = pitchPID:step(pitch, dt) - S_KD * angVel.x
        local rollOut  = rollPID:step(roll,   dt) - S_KD * angVel.z
        pitchOut = clamp(pitchOut, O_MIN, O_MAX)
        rollOut  = clamp(rollOut,  O_MIN, O_MAX)

        -- ---- Split-channel mix (GLM lift + corner attitude trim) ----
        local glm, fl, fr, bl, br = setMotors(coll, pitchOut, rollOut)

        -- ---- Publish to the shared frame (render loop draws it) ----
        -- The control loop no longer draws.  It only records the most
        -- recent telemetry plus the wall-clock time it arrived; the
        -- independent render loop interpolates between successive
        -- frames for smooth sub-tick scrolling.
        FRAME.prev = FRAME.cur
        FRAME.cur  = {
            pitch = pitch, roll = roll,
            angX  = angVel.x, angZ = angVel.z,
            glm = glm, fl = fl, fr = fr, bl = bl, br = br,
            iP = pitchPID.integral, iR = rollPID.integral,
            alt = pos.y, targetAlt = TARGET_ALT, velY = velY,
            rpm = coll, ff = ff, pidCorr = pidCorr, velDamp = velDamp,
            altI = altPID.integral, k = k_est, mass = mass,
            pressure = pressure,
        }
        FRAME.t_prev = FRAME.t_cur
        FRAME.t_cur  = os.clock()
        FRAME.seq    = FRAME.seq + 1
    end
end


-- ================================================================
--  §12  REDSTONE ALTITUDE STEP
--  RIGHT side held >= RS_HOLD_TIME  -> target + ALT_STEP
--  LEFT  side held >= RS_HOLD_TIME  -> target - ALT_STEP
-- ================================================================

local function redstoneLoop()
    local riseTime = { right = nil, left = nil }
    while true do
        os.pullEvent("redstone")
        local now = os.clock()

        local rRight = redstone.getInput("right")
        if rRight and not riseTime.right then
            riseTime.right = now
        elseif not rRight and riseTime.right then
            if (now - riseTime.right) >= RS_HOLD_TIME then
                TARGET_ALT = TARGET_ALT + ALT_STEP
                altPID:setSP(TARGET_ALT); altPID:reset()
                term.setCursorPos(1, 16); term.clearLine()
                print("RS: alt +" .. ALT_STEP .. " -> " .. TARGET_ALT .. " m")
            end
            riseTime.right = nil
        end

        local rLeft = redstone.getInput("left")
        if rLeft and not riseTime.left then
            riseTime.left = now
        elseif not rLeft and riseTime.left then
            if (now - riseTime.left) >= RS_HOLD_TIME then
                TARGET_ALT = TARGET_ALT - ALT_STEP
                altPID:setSP(TARGET_ALT); altPID:reset()
                term.setCursorPos(1, 16); term.clearLine()
                print("RS: alt -" .. ALT_STEP .. " -> " .. TARGET_ALT .. " m")
            end
            riseTime.left = nil
        end
    end
end


