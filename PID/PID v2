local controlStep = makeControlStep()

term.clear(); term.setCursorPos(1, 1)
print("FUSED FLIGHT CONTROLLER running. Ctrl+T to stop.")
printHelp()
print("")

-- Decoupled render loop.  Runs independently of the control loop:
--   * ingests a new ring-buffer sample only when FRAME.seq advances
--   * repaints every iteration, sliding the trace by a wall-clock
--     fraction of one column so motion is smooth between data ticks
--   * yields on a self-queued event (NOT sleep, which floors at one
--     game tick) so it can repaint several times per game tick
local function renderLoop()
    local EV = "fg_render"
    os.queueEvent(EV)
    local minDt = 1 / RENDER_HZ
    local lastPaint = os.clock()

    while true do
        os.pullEvent(EV)

        -- Ingest at most one new sample per control tick.
        if FRAME.seq ~= FRAME.seen and FRAME.cur then
            ingestFrame(FRAME.cur)
            FRAME.seen = FRAME.seq
        end

        -- scrollFrac: how far (0..1) it's between the last control
        -- tick and the next expected one, by real elapsed time.  Drives
        -- the sub-column glide.  Clamped so a late tick doesn't lurch.
        local sf = 0
        if FRAME.t_cur > 0 then
            local period = FRAME.t_cur - FRAME.t_prev
            if period <= 0 then period = LOOP_RATE end
            sf = (os.clock() - FRAME.t_cur) / period
            if sf < 0 then sf = 0 elseif sf > 1 then sf = 1 end
        end

        renderFrame(FRAME.cur, sf)

        -- Pace to ~RENDER_HZ.  os.clock granularity in CC is coarse;
        -- this just avoids spinning hotter than needed.
        local nowp = os.clock()
        local rest = minDt - (nowp - lastPaint)
        lastPaint = nowp
        if rest and rest > 0 then
            -- A zero-length timer still yields without flooring to a
            -- full game tick the way sleep() would.
            local tid = os.startTimer(0)
            local ev, p
            repeat ev, p = os.pullEvent() until
                (ev == "timer" and p == tid)
        end
        os.queueEvent(EV)
    end
end

local ok, err = pcall(function()
    parallel.waitForAny(
        function()
            while true do
                local ok2, e2 = pcall(controlStep)
                if not ok2 then
                    term.setCursorPos(1, 14); term.clearLine()
                    print("WARN: " .. tostring(e2))
                end
                sleep(LOOP_RATE)
            end
        end,
        renderLoop,
        inputLoop,
        redstoneLoop
    )
end)

stopMotors()
gpuRelease()
term.clear(); term.setCursorPos(1, 1)
if not ok and err ~= "Terminated" then
    printError("Crashed: " .. tostring(err))
else
    print("Stopped. Motors zeroed.")
end
